---
import { features } from "../data/site";
---

<section class="section" id="producto">
  <div class="container">
    <div class="eyebrow">Cómo funciona</div>
    <h2 class="title">Producto pensado para llegar acompañado al evento.</h2>
    <p class="lead" style="margin-bottom: 48px;">
      Distinto a las apps de citas: el evento es el contexto y el detonante del encuentro.
      Distinto a Meetup: el matching es 1-a-1, personalizado por compatibilidad.
    </p>

    <div class="grid grid-3">
      {features.map((f) => (
        <div class="card feature">
          <img class="icon" src={f.icon} alt="" />
          <h3>{f.title}</h3>
          <p>{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
