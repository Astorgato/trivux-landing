---
import { site } from "../data/site";
import EventosMockup from "./EventosMockup.astro";
---

<section class="hero" id="top">
  <div class="container hero-grid">
    <div>
      <div class="eyebrow">MVP en pruebas · Santiago de Chile</div>
      <h1>
        Encuentra amigos.<br />
        <span class="gradient">Comparte tus eventos.</span> Vive la experiencia Trivux.
      </h1>
      <p class="lead">
        Trivux conecta personas que asisten a los mismos conciertos, fiestas, obras y partidos en
        Santiago. Conoce a quién más va, conversen antes y coordinen el encuentro.
      </p>
      <div class="hero-actions">
        <a href="#descargar" class="btn btn-primary">
          Descargar APK
        </a>
        <a href="#producto" class="btn btn-secondary">Ver cómo funciona</a>
        <span class="hero-version">{site.apkVersion}</span>
      </div>
    </div>
    <EventosMockup />
  </div>
</section>
