---
import { team } from "../data/site";

// Detecta en build time qué fotos de equipo existen en /public/assets/team/
// para renderizar <img> si están, o las iniciales como fallback.
const teamImages = import.meta.glob("/public/assets/team/*.{png,jpg,jpeg,webp}", {
  eager: true,
  query: "?url",
  import: "default",
});

function avatarFor(filename: string): string | null {
  const key = `/public/assets/team/${filename}`;
  const url = (teamImages as Record<string, string>)[key];
  return url || null;
}

const teamWithImages = team.map((p) => {
  // Acepta png, jpg, jpeg, webp con el nombre base del avatar (sin extensión).
  const base = p.avatar.replace(/^.*\//, "").replace(/\.[^.]+$/, "");
  const found =
    avatarFor(`${base}.png`) ||
    avatarFor(`${base}.jpg`) ||
    avatarFor(`${base}.jpeg`) ||
    avatarFor(`${base}.webp`);
  return {
    ...p,
    imageUrl: found ? p.avatar : null, // si existe, exponemos la ruta pública
  };
});
---

<section class="section" id="equipo">
  <div class="container">
    <div class="eyebrow">El equipo</div>
    <h2 class="title">Quienes están detrás del desarrollo.</h2>
    <p class="lead" style="margin-bottom: 48px;">
      Un equipo pequeño y multidisciplinario: ingeniería matemática para la lógica de matching,
      periodismo y diseño UX/UI para la voz y la experiencia de marca.
    </p>

    <div class="member-grid">
      {teamWithImages.map((p) => (
        <div class="card">
          <div class="member">
            <div class="member-avatar">
              {p.imageUrl ? (
                <img src={p.imageUrl} alt={p.name} />
              ) : (
                <span>{p.avatarFallback}</span>
              )}
            </div>
            <div>
              <h3>{p.name}</h3>
              <div class="role">{p.role}</div>
              <p>{p.bio}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
