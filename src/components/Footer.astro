---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-grid">
    <div class="brand" style="display: flex; align-items: center; gap: 10px; color: var(--text-prim);">
      <img src="/assets/logo-trivux.png" alt="Trivux" />
      <span style="font-weight: 700;">Trivux</span>
      <span style="color: var(--text-sec); margin-left: 8px;">
        © {year} · Hecho en Santiago, Chile.
      </span>
    </div>
    <div style="display: flex; gap: 18px; flex-wrap: wrap;">
      <a href={`mailto:${site.email}`}>{site.email}</a>
      <a href="#producto">Producto</a>
      <a href="#mision">Misión</a>
      <a href="#equipo">Equipo</a>
    </div>
  </div>
</footer>
