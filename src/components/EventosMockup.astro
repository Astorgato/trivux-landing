---
// Pantalla real de eventos (screenshot del MVP en producción).
// Para reemplazar la imagen: dejar un nuevo PNG/WEBP en
// landing/public/assets/screens/eventos.png con la misma proporción.
---

<div class="screen-wrap">
  <div class="screen-glow"></div>
  <img
    class="screen-img"
    src="/assets/screens/eventos.jpeg"
    alt="Pantalla de eventos de Trivux: header con buscador, chips de categorías y subgéneros, filtros por fecha y feed de eventos."
    width="540"
    height="1110"
    loading="eager"
    decoding="async"
  />
</div>

<style>
  .screen-wrap {
    position: relative;
    width: 100%;
    max-width: 340px;
    margin-left: auto;
  }
  .screen-glow {
    position: absolute;
    inset: -40px;
    background:
      radial-gradient(60% 50% at 30% 0%, rgba(123, 57, 236, 0.45) 0%, transparent 60%),
      radial-gradient(60% 60% at 80% 80%, rgba(255, 45, 149, 0.30) 0%, transparent 60%);
    filter: blur(40px);
    z-index: 0;
    pointer-events: none;
  }
  .screen-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    display: block;
    border-radius: 32px;
    border: 1px solid var(--border);
    box-shadow:
      0 30px 80px rgba(123, 57, 236, 0.30),
      0 10px 30px rgba(0, 0, 0, 0.6);
  }
  @media (max-width: 920px) {
    .screen-wrap { margin: 32px auto 0; max-width: 300px; }
  }
</style>
