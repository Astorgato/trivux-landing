---
// Mockup HTML/CSS de la pantalla de eventos.
// Recrea el layout real (hero carousel + secciones con carruseles horizontales)
// con la paleta y tipografía de la app, sin necesidad de screenshots.
---

<div class="device">
  <div class="device-notch"></div>
  <div class="device-screen">
    <!-- Status bar simulada -->
    <div class="status-bar">
      <span class="time">22:41</span>
      <div class="status-icons">
        <span class="dot-pill"></span>
        <span class="dot-pill"></span>
        <span class="dot-pill long"></span>
      </div>
    </div>

    <!-- Header con logo + búsqueda -->
    <div class="app-header">
      <div class="app-brand">
        <img src="/assets/logo-trivux.png" alt="" />
        <span>Eventos</span>
      </div>
      <div class="search-bar">
        <img src="/assets/icons/Buscar.png" alt="" class="search-icon" />
        <span class="search-placeholder">Buscar evento, artista…</span>
      </div>
    </div>

    <!-- Hero carousel -->
    <div class="hero-card">
      <div class="hero-overlay"></div>
      <div class="hero-tags">
        <span class="hero-tag fire">
          <img src="/assets/icons/fire.png" alt="" /> Trending
        </span>
      </div>
      <div class="hero-info">
        <div class="hero-date">VIE 2 MAY · 22:00</div>
        <div class="hero-title">Boiler Room Santiago</div>
        <div class="hero-venue">
          <img src="/assets/icons/pin.png" alt="" /> Galpón Víctor Jara
        </div>
      </div>
      <div class="dots">
        <span class="dot active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
    </div>

    <!-- Sección 1: Esta semana -->
    <div class="section-row">
      <div class="section-head">
        <div class="section-title">
          <img src="/assets/icons/calendar.png" alt="" />
          <span>Esta semana</span>
        </div>
        <span class="section-count">12</span>
      </div>
      <div class="cards-row">
        <div class="mini-card">
          <div class="mini-cover techno">
            <span class="badge">SÁB</span>
          </div>
          <div class="mini-meta">
            <div class="mini-title">Movement Chile · Techno</div>
            <div class="mini-venue">Estación Mapocho</div>
          </div>
        </div>
        <div class="mini-card">
          <div class="mini-cover indie">
            <span class="badge">DOM</span>
          </div>
          <div class="mini-meta">
            <div class="mini-title">Festival Indie Pop</div>
            <div class="mini-venue">Parque Bicentenario</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Sección 2: Cerca de ti -->
    <div class="section-row">
      <div class="section-head">
        <div class="section-title">
          <img src="/assets/icons/pin.png" alt="" />
          <span>Cerca de ti</span>
        </div>
        <span class="section-count">8</span>
      </div>
      <div class="cards-row">
        <div class="mini-card">
          <div class="mini-cover jazz">
            <span class="badge">HOY</span>
          </div>
          <div class="mini-meta">
            <div class="mini-title">Jazz en La Reforma</div>
            <div class="mini-venue">Providencia · 21:00</div>
          </div>
        </div>
        <div class="mini-card">
          <div class="mini-cover teatro">
            <span class="badge">JUE</span>
          </div>
          <div class="mini-meta">
            <div class="mini-title">Hamlet — Teatro UC</div>
            <div class="mini-venue">Ñuñoa</div>
          </div>
        </div>
      </div>
    </div>

    <!-- Tab bar flotante (replica el customTabBar de la app) -->
    <div class="tab-bar">
      <div class="tab-item">
        <img src="/assets/icons/swipe-inactive.png" alt="" />
      </div>
      <div class="tab-item active">
        <img src="/assets/icons/eventos.png" alt="" />
      </div>
      <div class="tab-item">
        <img src="/assets/icons/chats-inactive.png" alt="" />
      </div>
      <div class="tab-item">
        <img src="/assets/icons/perfil-inactive.png" alt="" />
      </div>
    </div>
  </div>
</div>

<style>
  .device {
    position: relative;
    width: 100%;
    max-width: 340px;
    margin-left: auto;
    aspect-ratio: 9 / 19;
    background: linear-gradient(180deg, #1a1a2e 0%, #0a0a18 100%);
    border-radius: 42px;
    padding: 12px;
    border: 2px solid #2a2a3e;
    box-shadow:
      0 0 0 6px rgba(255, 255, 255, 0.02),
      0 30px 80px rgba(123, 57, 236, 0.30),
      0 10px 30px rgba(0, 0, 0, 0.6);
  }
  .device-notch {
    position: absolute;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: 90px;
    height: 24px;
    background: #000;
    border-radius: 14px;
    z-index: 10;
  }
  .device-screen {
    position: relative;
    width: 100%;
    height: 100%;
    background: var(--bg);
    border-radius: 32px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    background-image:
      radial-gradient(80% 40% at 50% 0%, rgba(123, 57, 236, 0.18) 0%, transparent 70%);
  }

  .status-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 24px 4px;
    color: var(--white);
    font-size: 11px;
    font-weight: 600;
    height: 36px;
  }
  .time { letter-spacing: 0.4px; }
  .status-icons { display: flex; gap: 4px; align-items: center; }
  .dot-pill {
    width: 12px; height: 5px; background: var(--white);
    border-radius: 2px; opacity: 0.85;
  }
  .dot-pill.long { width: 16px; }

  .app-header {
    padding: 8px 18px 10px;
  }
  .app-brand {
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 10px;
  }
  .app-brand img { height: 22px; width: auto; }
  .app-brand span { color: var(--white); font-weight: 700; font-size: 16px; }
  .search-bar {
    display: flex; align-items: center; gap: 8px;
    background: var(--input);
    border: 1px solid var(--purple-active);
    border-radius: 999px;
    padding: 7px 14px;
    height: 32px;
  }
  .search-icon { width: 13px; height: 13px; opacity: 0.65; }
  .search-placeholder { color: var(--text-sec); font-size: 11.5px; }

  .hero-card {
    position: relative;
    margin: 6px 16px 14px;
    height: 130px;
    border-radius: 16px;
    overflow: hidden;
    background:
      radial-gradient(140% 100% at 0% 0%, #ff2d95 0%, transparent 55%),
      radial-gradient(140% 100% at 100% 100%, #7b39ec 0%, transparent 55%),
      linear-gradient(135deg, #2a0a4a 0%, #4a1668 100%);
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(7, 5, 14, 0.65) 100%);
  }
  .hero-tags {
    position: absolute; top: 10px; left: 10px;
    display: flex; gap: 4px; z-index: 2;
  }
  .hero-tag {
    display: inline-flex; align-items: center; gap: 4px;
    background: rgba(7, 5, 14, 0.5);
    backdrop-filter: blur(8px);
    color: var(--white);
    font-size: 9.5px;
    font-weight: 700;
    padding: 3px 8px;
    border-radius: 999px;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    border: 1px solid rgba(255,255,255,0.15);
  }
  .hero-tag img { width: 10px; height: 10px; }
  .hero-info {
    position: absolute; bottom: 14px; left: 12px; right: 12px;
    z-index: 2;
  }
  .hero-date {
    color: var(--purple-light);
    font-weight: 700;
    font-size: 9.5px;
    letter-spacing: 1px;
    margin-bottom: 3px;
  }
  .hero-title {
    color: var(--white);
    font-size: 15px;
    font-weight: 800;
    line-height: 1.15;
    margin-bottom: 3px;
    letter-spacing: -0.01em;
  }
  .hero-venue {
    display: inline-flex; align-items: center; gap: 4px;
    color: var(--text-light);
    font-size: 10px;
  }
  .hero-venue img { width: 10px; height: 10px; opacity: 0.85; }
  .dots {
    position: absolute; bottom: 6px; left: 50%;
    transform: translateX(-50%);
    display: flex; gap: 4px;
    z-index: 2;
  }
  .dot {
    width: 5px; height: 5px;
    background: rgba(255, 255, 255, 0.35);
    border-radius: 999px;
  }
  .dot.active { background: var(--white); width: 14px; }

  .section-row { padding: 0 16px; margin-bottom: 12px; }
  .section-head {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 7px;
  }
  .section-title {
    display: flex; align-items: center; gap: 5px;
    color: var(--white);
    font-weight: 700;
    font-size: 12px;
  }
  .section-title img { width: 13px; height: 13px; }
  .section-count {
    color: var(--purple-light);
    font-size: 10px;
    font-weight: 700;
    background: var(--purple-dim);
    border: 1px solid var(--purple-active);
    padding: 2px 7px;
    border-radius: 999px;
  }

  .cards-row { display: flex; gap: 8px; }
  .mini-card {
    flex: 1;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .mini-cover {
    position: relative;
    height: 60px;
    overflow: hidden;
  }
  .mini-cover .badge {
    position: absolute;
    top: 6px; left: 6px;
    background: rgba(7, 5, 14, 0.7);
    color: var(--white);
    font-size: 8.5px;
    font-weight: 700;
    padding: 2px 6px;
    border-radius: 4px;
    letter-spacing: 0.5px;
    backdrop-filter: blur(6px);
  }
  .mini-cover.techno {
    background:
      radial-gradient(circle at 30% 30%, #ff2d95 0%, transparent 55%),
      linear-gradient(135deg, #1a0738 0%, #331959 100%);
  }
  .mini-cover.indie {
    background:
      radial-gradient(circle at 70% 30%, #06b6d4 0%, transparent 55%),
      linear-gradient(135deg, #1a0738 0%, #331959 100%);
  }
  .mini-cover.jazz {
    background:
      radial-gradient(circle at 50% 50%, #f59e0b 0%, transparent 55%),
      linear-gradient(135deg, #2a0a4a 0%, #1a0738 100%);
  }
  .mini-cover.teatro {
    background:
      radial-gradient(circle at 30% 70%, #a855f7 0%, transparent 55%),
      linear-gradient(135deg, #4a1668 0%, #1a0738 100%);
  }
  .mini-meta { padding: 7px 9px 9px; }
  .mini-title {
    color: var(--white);
    font-size: 10.5px;
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 3px;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
  }
  .mini-venue {
    color: var(--text-sec);
    font-size: 9px;
  }

  .tab-bar {
    position: absolute;
    bottom: 16px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 0;
    background: rgba(22, 22, 32, 0.92);
    backdrop-filter: blur(20px);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 6px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }
  .tab-item {
    width: 38px; height: 38px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 999px;
    transition: background 0.2s ease;
  }
  .tab-item img { width: 18px; height: 18px; opacity: 0.55; }
  .tab-item.active {
    background: linear-gradient(135deg, var(--purple) 0%, var(--purple-alt) 100%);
  }
  .tab-item.active img { opacity: 1; }

  @media (max-width: 920px) {
    .device { margin: 32px auto 0; max-width: 320px; }
  }
</style>
