---
import { site } from "../data/site";
---

<header class="header">
  <div class="container header-inner">
    <a href="#top" class="brand">
      <img class="logo-dark" src="/assets/logo-trivux.png" alt="Trivux" />
      <img class="logo-light" src="/assets/logo-trivux-light.png" alt="Trivux" />
      <span>{site.name}</span>
    </a>
    <nav class="nav">
      <a href="#producto">Producto</a>
      <a href="#metricas">Métricas</a>
      <a href="#mision">Misión</a>
      <a href="#equipo">Equipo</a>
      <a href="#descargar">Descargar</a>
    </nav>
    <div class="header-actions">
      <button class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema">
        <!-- Sol (modo oscuro activo) -->
        <svg class="icon-sun" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <!-- Luna (modo claro activo) -->
        <svg class="icon-moon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
      <a href="#descargar" class="btn btn-primary" style="padding: 10px 18px; font-size: 14px;">
        Probar el MVP
      </a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("theme-toggle");
  btn?.addEventListener("click", () => {
    const html = document.documentElement;
    const next = html.getAttribute("data-theme") === "light" ? "dark" : "light";
    html.setAttribute("data-theme", next);
    localStorage.setItem("theme", next);
  });
</script>
