---
import "../styles/global.css";
import { site } from "../data/site";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — ${site.tagline}`,
  description = "Trivux conecta a personas en Santiago que asisten a los mismos eventos. No vayas solo: descubre quién más va y coordinen el encuentro.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#07050E" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`https://${site.domain}`} />
    <meta property="og:image" content="/assets/logo-trivux.png" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/png" href="/assets/logo-trivux.png" />

    <!-- Inter (misma tipografía que la app) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
